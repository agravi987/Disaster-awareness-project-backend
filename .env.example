PORT=5000
MONGO_URI=mongodb://localhost:27017/disaster_awareness_db

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Free NewsAPI key (demo)
NEWS_API_KEY=

# News API URL settings
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_EVERYTHING_PATH=/everything
NEWS_DEFAULT_LOCATION=India

# Low-limit protection
NEWS_CACHE_TTL_MS=900000

# AI quiz generation
GROQ_API_KEY=

# Cloudinary upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Set an identifiable user-agent for geocoding requests
NOMINATIM_USER_AGENT=DisasterAwarenessLearningPlatform/1.0 (youremail@example.com)
